# Application Settings
APP_NAME=Agent Memory Cloud API
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/v1
API_KEY_HEADER=X-API-Key
MAX_CONTENT_SIZE_BYTES=10240

# PostgreSQL + pgvector configuration
# Replace with your actual database credentials
DATABASE_TYPE=postgres
DATABASE_URL=postgresql+asyncpg://<db_user>:<db_password>@<db_host>:5432/<db_name>
DATABASE_ECHO=false

# Auth
# Generate a strong secret key: openssl rand -hex 32
JWT_SECRET_KEY=<your-strong-jwt-secret-key-here>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=***

# Redis Configuration (for production rate limiting)
# Format: redis://[:password]@host:port/db
# Example: redis://localhost:6379/0
# Leave empty to use in-memory rate limiting (not recommended for production)
REDIS_URL=

# PostHog Analytics Configuration
# Get your PostHog project API key from https://posthog.com/project/api_key
# Required for event tracking in production
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostHog host (default: https://app.posthog.com)
POSTHOG_HOST=https://app.posthog.com

# Enable/disable PostHog tracking (default: enabled if API key is set)
POSTHOG_ENABLED=true
