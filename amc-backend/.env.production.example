# Agent Memory Cloud production environment example
# Copy to .env.production and replace placeholder values before deploy.

APP_NAME=Agent Memory Cloud API
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/v1
API_KEY_HEADER=X-API-Key
MAX_CONTENT_SIZE_BYTES=10240

# Production database must use Postgres + pgvector.
DATABASE_TYPE=postgres
DATABASE_URL=postgresql+asyncpg://amc_user:change-me@db.example.com:5432/amc
DATABASE_ECHO=false

# Container/runtime
PORT=8000
LOG_LEVEL=INFO

# Stripe billing configuration (required for beta launch)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_STARTER_PRICE_ID=price_starter_monthly_id
STRIPE_PRO_PRICE_ID=price_pro_monthly_id
FRONTEND_URL=https://app.agentmemory.cloud
