# PostgreSQL + pgvector Load Test Environment
# Copy to .env.loadtest and adjust for the target environment.

APP_NAME=Agent Memory Cloud API
APP_VERSION=0.1.0
DEBUG=false
API_V1_PREFIX=/v1
API_KEY_HEADER=X-API-Key
MAX_CONTENT_SIZE_BYTES=10240

# PostgreSQL + pgvector configuration
DATABASE_TYPE=postgres
DATABASE_URL=postgresql+asyncpg://amc:amc_password@localhost:5432/amc
DATABASE_ECHO=false

# Load test parameters
AMC_LOADTEST_HOST=http://localhost:8000
AMC_LOADTEST_API_KEY=test-api-key-load-test
AMC_LOADTEST_USERS=100
AMC_LOADTEST_SPAWN_RATE=10
AMC_LOADTEST_DURATION=300s
AMC_LOADTEST_HTML_REPORT=reports/loadtest-report-postgres.html
