{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd amc-frontend && npm install && npm run build",
  "outputDirectory": "amc-frontend/out",
  "installCommand": "npm install",
  "framework": null,
  "regions": ["fra1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
